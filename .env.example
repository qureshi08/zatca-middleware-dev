# ============================================================================
# ZATCA Middleware — environment template. Copy to .env.local and fill in.
# .env* files are gitignored — never commit real secrets.
# ============================================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
APP_BASE_URL=http://localhost:3000
# 32-byte key, base64, for AES-256-GCM encryption of secrets at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=

# --- Google auth ---
# Configured in the Supabase dashboard (Authentication → Providers → Google).
# Add the Google OAuth Client ID/Secret there; no app env var needed.

# --- ZATCA endpoints (Demo = simulation/123456, Real = core) ---
ZATCA_DEV_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_SIMULATION_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/simulation
ZATCA_CORE_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/core

# --- Email alerts (Resend) — failures + CSID expiry ---
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@example.com
